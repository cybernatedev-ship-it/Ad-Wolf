[Unit]
Description=Ad-Wolf DNS Filter
Documentation=https://github.com/anomalyco/Ad-Wolf
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/dns-filter -c /etc/dns-filter/config.toml
Restart=on-failure
RestartSec=5
User=nobody
Group=nogroup
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/dns-filter
StateDirectory=dns-filter

[Install]
WantedBy=multi-user.target
